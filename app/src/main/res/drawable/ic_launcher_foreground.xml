<?xml version="1.0" encoding="utf-8"?>
<!--
  Aura · App Icon Foreground
  设计语言：双环 Aura 符号
    外环 = 青绿扩散光（#00D4B4）代表创意向外辐射
    内环 = 紫罗兰能量（#9B7AFF）代表 AI 核心动力
    4 粒菱形光点 = 像素/星尘，代表每一次创作的独特火花
    中心星芒 = 纯白灵感之光
  安全区：18dp–90dp（内容集中在 26dp–82dp）
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── 外环：青绿 Aura 扩散圈（radius=26, stroke=2.5） ─────────────────
         圆心(54,54)，半径26 → 圆路径 M(54-26),54 = M28,54 -->
    <path
        android:pathData="M28,54 A26,26 0 1,1 80,54 A26,26 0 1,1 28,54 Z"
        android:fillColor="#00000000"
        android:strokeColor="#00D4B4"
        android:strokeWidth="2.2"/>

    <!-- 外环顶部微弱高光弧（增加立体感） -->
    <path
        android:pathData="M38,32 A26,26 0 0,1 70,32"
        android:fillColor="#00000000"
        android:strokeColor="#80FFFFFF"
        android:strokeWidth="0.8"/>

    <!-- ── 内环：紫罗兰 AI 核心圈（radius=15, stroke=2） ──────────────────
         M(54-15),54 = M39,54 -->
    <path
        android:pathData="M39,54 A15,15 0 1,1 69,54 A15,15 0 1,1 39,54 Z"
        android:fillColor="#1A0B2E"
        android:strokeColor="#9B7AFF"
        android:strokeWidth="2.0"/>

    <!-- ── 4 粒菱形光点（位于两环之间，45°方向）─────────────────────────
         位于半径 ~20.5 处，45°角坐标：
           NE: (54+14.5, 54-14.5) = (68.5, 39.5)
           SE: (54+14.5, 54+14.5) = (68.5, 68.5)
           SW: (54-14.5, 54+14.5) = (39.5, 68.5)
           NW: (54-14.5, 54-14.5) = (39.5, 39.5)
         每粒菱形：上下左右各 2dp -->
    <!-- NE 光点 -->
    <path
        android:pathData="M68.5,37.5 L70.5,39.5 L68.5,41.5 L66.5,39.5 Z"
        android:fillColor="#00D4B4"/>
    <!-- SE 光点 -->
    <path
        android:pathData="M68.5,66.5 L70.5,68.5 L68.5,70.5 L66.5,68.5 Z"
        android:fillColor="#9B7AFF"/>
    <!-- SW 光点 -->
    <path
        android:pathData="M39.5,66.5 L41.5,68.5 L39.5,70.5 L37.5,68.5 Z"
        android:fillColor="#00D4B4"/>
    <!-- NW 光点 -->
    <path
        android:pathData="M39.5,37.5 L41.5,39.5 L39.5,41.5 L37.5,39.5 Z"
        android:fillColor="#9B7AFF"/>

    <!-- ── 中心 4 芒星芒（灵感火花）───────────────────────────────────────
         外尖：上(54,43) 右(65,54) 下(54,65) 左(43,54)
         内凹：(56,52) (56,56) (52,56) (52,52) -->
    <path
        android:pathData="M54,43 L56,52 L65,54 L56,56 L54,65 L52,56 L43,54 L52,52 Z"
        android:fillColor="#FFFFFF"/>

    <!-- 中心亮核（纯白，小圆） -->
    <path
        android:pathData="M51,54 A3,3 0 1,1 57,54 A3,3 0 1,1 51,54 Z"
        android:fillColor="#FFFFFF"/>

    <!-- 外圈右上角点缀小星（装饰） -->
    <path
        android:pathData="M76,34 L77,36.5 L79.5,37.5 L77,38.5 L76,41 L75,38.5 L72.5,37.5 L75,36.5 Z"
        android:fillColor="#60D4B4"/>

</vector>
